{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/orthodox-resources/schema.json",
  "title": "Orthodox Jewish Study Resources — Directory Data Model",
  "description": "Schema for a browsable directory of Orthodox Jewish study resources. The top-level object is a database snapshot containing four entity collections (traditions, resources, texts, authorities) plus enum reference lists. Relationships are expressed by ID references so the same resource can belong to many traditions, etc.",
  "type": "object",
  "required": ["meta", "traditions", "resources"],
  "additionalProperties": false,

  "properties": {
    "meta": { "$ref": "#/$defs/meta" },
    "traditions": {
      "type": "array",
      "description": "Hierarchical tree of traditions/streams/dynasties. Nesting is expressed via parentId.",
      "items": { "$ref": "#/$defs/tradition" }
    },
    "resources": {
      "type": "array",
      "description": "The core directory entries: websites, apps, hotlines, publishers, institutions, archives.",
      "items": { "$ref": "#/$defs/resource" }
    },
    "texts": {
      "type": "array",
      "description": "Canonical works (e.g. Mishnah Berurah, Ben Ish Chai). Referenced by resources that host or are built around them.",
      "items": { "$ref": "#/$defs/text" }
    },
    "authorities": {
      "type": "array",
      "description": "People: poskim, rebbes, founders, maggidei shiur.",
      "items": { "$ref": "#/$defs/authority" }
    }
  },

  "$defs": {

    "meta": {
      "type": "object",
      "description": "Snapshot-level metadata.",
      "required": ["version", "generatedAt"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string", "description": "Semantic version of this dataset." },
        "generatedAt": { "type": "string", "format": "date", "description": "Date this snapshot was produced." },
        "source": { "type": "string", "description": "Provenance note." },
        "disclaimer": { "type": "string" }
      }
    },

    "slug": {
      "type": "string",
      "description": "URL-safe stable identifier used as a primary key and in routes.",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 2,
      "maxLength": 80
    },

    "language": {
      "type": "string",
      "description": "ISO 639 language code used for content/UI.",
      "enum": ["en", "he", "yi", "arc", "lad", "gez", "ru", "fr", "es", "pt", "mixed"]
    },

    "tradition": {
      "type": "object",
      "description": "A node in the tradition tree (e.g. 'Haredi', 'Hasidic', 'Satmar', or a Sephardic sub-rite).",
      "required": ["id", "name", "level"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/slug" },
        "parentId": {
          "description": "ID of the parent tradition, or null for a top-level branch.",
          "oneOf": [{ "$ref": "#/$defs/slug" }, { "type": "null" }]
        },
        "name": { "type": "string" },
        "altNames": { "type": "array", "items": { "type": "string" } },
        "level": {
          "type": "string",
          "description": "Depth/role in the hierarchy.",
          "enum": ["branch", "stream", "dynasty", "rite", "community"]
        },
        "description": { "type": "string" },
        "primaryLanguages": {
          "type": "array",
          "items": { "$ref": "#/$defs/language" }
        },
        "audioFirst": {
          "type": "boolean",
          "description": "True where audio (often Yiddish) is the native medium rather than text/English web (e.g. Satmar, Belz). Drives UX decisions."
        },
        "notes": { "type": "string" }
      }
    },

    "resource": {
      "type": "object",
      "description": "A single directory entry.",
      "required": ["id", "name", "type", "traditionIds", "access"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/slug" },
        "name": { "type": "string" },
        "altNames": { "type": "array", "items": { "type": "string" } },
        "type": {
          "type": "string",
          "description": "What kind of resource this is.",
          "enum": [
            "text-library", "shiur-library", "daily-study", "halacha",
            "publisher", "institution", "organization", "archive",
            "hotline", "app", "general-portal", "kashrus", "counter-missionary"
          ]
        },
        "url": {
          "description": "Primary URL, or null for offline/print-only/phone-only resources.",
          "oneOf": [{ "type": "string", "format": "uri" }, { "type": "null" }]
        },
        "altUrls": {
          "type": "array",
          "description": "Mirror/related domains.",
          "items": { "type": "string", "format": "uri" }
        },
        "phone": { "type": "string", "description": "For hotlines (e.g. Yiddish24)." },
        "description": { "type": "string" },
        "traditionIds": {
          "type": "array",
          "description": "Traditions this resource serves (many-to-many). Use the most specific applicable IDs; cross-denominational resources list 'universal'.",
          "minItems": 1,
          "items": { "$ref": "#/$defs/slug" }
        },
        "languages": {
          "type": "array",
          "description": "Languages of the resource's CONTENT — the texts/shiurim themselves (distinct from the navigation language).",
          "items": { "$ref": "#/$defs/language" }
        },
        "uiLanguages": {
          "type": "array",
          "description": "Languages of the INTERFACE/NAVIGATION — what a user must read to operate the site (menus, search, buttons). A resource with uiLanguages ['he'] cannot be navigated without Hebrew, even if some content is in other languages. Omit if unknown; treat a resource as English-navigable only when 'en' is present.",
          "items": { "$ref": "#/$defs/language" }
        },
        "medium": {
          "type": "array",
          "description": "Delivery formats offered.",
          "items": { "type": "string", "enum": ["text", "audio", "video", "print", "phone"] }
        },
        "textIds": {
          "type": "array",
          "description": "Canonical texts this resource hosts or is built around.",
          "items": { "$ref": "#/$defs/slug" }
        },
        "authorityIds": {
          "type": "array",
          "description": "People centrally associated with this resource.",
          "items": { "$ref": "#/$defs/slug" }
        },
        "access": {
          "type": "string",
          "description": "Cost/openness model. 'api-open' means programmatically reusable (e.g. Sefaria); 'copyright-restricted' flags content that cannot be rehosted (e.g. ArtScroll).",
          "enum": ["free", "free-registration", "freemium", "paid", "api-open", "copyright-restricted"]
        },
        "hasApi": { "type": "boolean" },
        "verification": { "$ref": "#/$defs/verification" },
        "flags": {
          "type": "array",
          "description": "Editorial caveats for human review before relying on the entry.",
          "items": { "type": "string" }
        }
      }
    },

    "verification": {
      "type": "object",
      "description": "Link/liveness checking metadata — first-class so the directory can surface stale entries.",
      "required": ["status"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["verified-live", "unconfirmed", "not-checked", "dead"]
        },
        "lastChecked": { "type": "string", "format": "date" },
        "note": { "type": "string" }
      }
    },

    "text": {
      "type": "object",
      "description": "A canonical work.",
      "required": ["id", "title"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/slug" },
        "title": { "type": "string" },
        "transliteration": { "type": "string" },
        "category": {
          "type": "string",
          "enum": ["tanakh", "talmud", "halacha", "responsa", "chassidus", "mussar", "kabbalah", "liturgy", "commentary", "other"]
        },
        "authorId": {
          "oneOf": [{ "$ref": "#/$defs/slug" }, { "type": "null" }]
        },
        "traditionIds": { "type": "array", "items": { "$ref": "#/$defs/slug" } },
        "onSefaria": { "type": "boolean" },
        "onHebrewbooks": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },

    "authority": {
      "type": "object",
      "description": "A person.",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/slug" },
        "name": { "type": "string" },
        "altNames": { "type": "array", "items": { "type": "string" } },
        "role": {
          "type": "array",
          "items": { "type": "string", "enum": ["posek", "rebbe", "rosh-yeshiva", "founder", "maggid-shiur", "author", "kes"] }
        },
        "traditionIds": { "type": "array", "items": { "$ref": "#/$defs/slug" } },
        "lifespan": { "type": "string", "description": "e.g. '1920-2013' or 'b. 1939'." },
        "notes": { "type": "string" }
      }
    }
  }
}
